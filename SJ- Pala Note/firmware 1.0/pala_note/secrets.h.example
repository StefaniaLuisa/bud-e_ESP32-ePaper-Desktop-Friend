#ifndef SECRETS_H
#define SECRETS_H

// ─── Your private credentials ──────────────────────────────────────────────
// Copy this file to `secrets.h` (in the same folder) and fill in your own
// values. `secrets.h` is git-ignored and must NEVER be committed — these keys
// are like passwords.

// Your 2.4 GHz WiFi network (the device and your Mac must be on the same one).
#define WIFI_SSID   "YOUR_WIFI_NAME"
#define WIFI_PASS   "YOUR_WIFI_PASSWORD"

// Groq API key — does the voice-to-text (speech recognition).
// Get one free at https://console.groq.com  ->  API Keys  ->  Create key.
// It starts with "gsk_".
#define GROQ_KEY    "gsk_REPLACE_WITH_YOUR_GROQ_KEY"

// Anthropic (Claude) API key — does the reasoning, titles, summaries, to-dos.
// Get one at https://console.anthropic.com  ->  API Keys  ->  Create key.
// It starts with "sk-ant-".
#define ANTHROPIC_KEY  "sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY"

#endif
